<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Lumified Hair</title>
    <link rel="icon" type="image/png" href="/favicon.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&display=swap"
      rel="stylesheet"
    />
    <style>
      *, *::before, *::after {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      html, body {
        height: 100%;
      }

      body {
        min-height: 100dvh;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0f0f0f;
        padding: clamp(1rem, 4vw, 2.5rem);
      }

      /* Portrait / tablet: stacked column */
      .card {
        display: grid;
        grid-template-areas:
          "i-am"
          "portrait"
          "name";
        grid-template-columns: 1fr;
        justify-items: center;
        align-items: center;
        gap: clamp(0.6rem, 2vmin, 1.2rem);
        width: 100%;
        max-width: 480px;
      }

      .i-am     { grid-area: i-am; }
      .portrait-wrap { grid-area: portrait; }
      .name     { grid-area: name; }

      .i-am {
        font-family: 'Cormorant Garamond', serif;
        font-style: italic;
        font-weight: 300;
        font-size: clamp(1rem, 3.5vmin, 1.7rem);
        letter-spacing: 0.45em;
        color: #a08b78;
        text-transform: lowercase;
        line-height: 1;
      }

      .portrait-wrap {
        width: clamp(180px, 52vmin, 360px);
        height: clamp(180px, 52vmin, 360px);
        border-radius: 50%;
        overflow: hidden;
        flex-shrink: 0;
        box-shadow:
          0 0 0 1px rgba(180, 140, 90, 0.25),
          0 0 50px rgba(180, 130, 60, 0.1),
          0 16px 48px rgba(0, 0, 0, 0.65);
      }

      .portrait-wrap img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center top;
        display: block;
      }

      .name {
        font-family: 'Cormorant Garamond', serif;
        font-weight: 300;
        font-size: clamp(4rem, 20vmin, 10rem);
        letter-spacing: 0.25em;
        color: #f0e6dc;
        line-height: 0.9;
        text-transform: uppercase;
      }

      /* Landscape (short screens — phone on its side) */
      @media (orientation: landscape) and (max-height: 520px) {
        .card {
          grid-template-areas:
            "portrait i-am"
            "portrait name";
          grid-template-columns: auto 1fr;
          grid-template-rows: 1fr 1fr;
          column-gap: clamp(1.5rem, 4vw, 3rem);
          row-gap: 0.2rem;
          max-width: 820px;
          justify-items: start;
          align-items: end;
        }

        .portrait-wrap {
          grid-row: 1 / 3;
          width: clamp(120px, 36vh, 240px);
          height: clamp(120px, 36vh, 240px);
          align-self: center;
        }

        .i-am {
          align-self: end;
          font-size: clamp(0.9rem, 2.5vh, 1.3rem);
          padding-bottom: 0.3em;
        }

        .name {
          align-self: start;
          font-size: clamp(3rem, 13vh, 6.5rem);
          letter-spacing: 0.18em;
        }
      }
    </style>
  </head>
  <body>
    <div class="card">
      <span class="i-am">i am</span>
      <div class="portrait-wrap">
        <img src="/lumi-caricature.png" alt="Lumi" />
      </div>
      <h1 class="name">Lumi</h1>
    </div>
  </body>
</html>
